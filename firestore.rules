rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;

      // Owner can write everything
      allow write: if request.auth != null && request.auth.uid == uid;

      // Any logged-in user can add/remove themselves from friendRequests
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friendRequests']);
    }

    // Usernames: public read so unregistered users can check availability
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Sticker collections: owner writes, logged-in users can read (for trades)
    match /userStickers/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
