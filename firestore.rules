rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;

      // Owner can write everything on their own document
      allow write: if request.auth != null && request.auth.uid == uid;

      // Anyone can update friendRequests and sentRequests on another user's doc
      // (used for sending/cancelling friend requests)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['friendRequests', 'sentRequests']);

      // Allow adding to friends + removing from sentRequests when accepting a request
      // Only valid if the writer (acceptor) is in the target's sentRequests
      allow update: if request.auth != null
        && resource.data.sentRequests.hasAll([request.auth.uid])
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['friends', 'sentRequests']);
    }

    // Usernames: public read, write only on creation
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Stickers: owner writes, friends can read
    match /userStickers/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
