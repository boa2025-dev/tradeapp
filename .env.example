# Copiá este archivo como .env.local y completá con tus credenciales de Firebase
# Pasos:
# 1. Ir a https://console.firebase.google.com
# 2. Crear un proyecto nuevo
# 3. Agregar una app web (ícono </>)
# 4. Activar Authentication → Sign-in method → Email/Password
# 5. Activar Firestore Database (modo producción o test)
# 6. Copiar las credenciales de configuración aquí

VITE_FIREBASE_API_KEY=tu_api_key
VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu_proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
